{
  "name": "buddhi-senior-support-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Buddhi - Senior Support Portal for H-West Ward, Mumbai",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm --workspace apps/web run build && npm --workspace apps/api run build",
    "start": "concurrently \"npm --workspace apps/api run start\" \"npm --workspace apps/web run start\"",
    "lint": "npm --workspaces run lint",
    "typecheck": "npm --workspaces run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
